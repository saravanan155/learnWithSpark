# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# Nebius Token Factory (REQUIRED by the course — at least one model call goes through it).
# Used by the research agent (B7), guardrail (B8), and later the quality judge.
NEBIUS_API_KEY=
# Verify this model id is live in the Nebius playground before relying on it (catalog changes).
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Anthropic / Claude — used later (B9) for the coding agent. Not needed yet for B7.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
